# ==============================================================================
# BASIC CONFIGURATION
# ==============================================================================

aws_region   = "us-east-1"
project_name = "my-app"
environment  = "dev"

# ==============================================================================
# LAMBDA TRIGGER CONFIGURATION
# ==============================================================================

# Enable/disable specific Lambda triggers
enable_pre_sign_up_trigger         = true
enable_post_confirmation_trigger   = true
enable_pre_authentication_trigger  = true
enable_post_authentication_trigger = true
enable_custom_message_trigger       = true
enable_user_migration_trigger       = false  # Set to true if you need user migration

# ==============================================================================
# USER MIGRATION CONFIGURATION
# ==============================================================================

# Only relevant if enable_user_migration_trigger = true
create_sample_migration_users = false  # Set to true for testing migration

# Sample users for migration testing (only used if create_sample_migration_users = true)
sample_migration_users = [
  {
    username = "legacy.user1@example.com"
    password = "TempPassword123!"
    email    = "legacy.user1@example.com"
    name     = "Legacy User One"
  },
  {
    username = "legacy.user2@example.com"
    password = "TempPassword456!"
    email    = "legacy.user2@example.com"
    name     = "Legacy User Two"
  }
]

# ==============================================================================
# HOSTED UI CONFIGURATION (OPTIONAL)
# ==============================================================================

create_hosted_ui_domain = false  # Set to true if you want to test with hosted UI
hosted_ui_domain_prefix = null   # Will use "my-app-dev-auth" if null

# ==============================================================================
# PASSWORD POLICY CONFIGURATION
# ==============================================================================

password_minimum_length         = 8
password_require_lowercase      = true
password_require_numbers        = true
password_require_symbols        = true
password_require_uppercase      = true
temporary_password_validity_days = 7

# ==============================================================================
# SECURITY CONFIGURATION
# ==============================================================================

advanced_security_mode = "AUDIT"  # or "ENFORCED" or "OFF"
mfa_configuration     = "OFF"     # or "OPTIONAL" or "ON"
