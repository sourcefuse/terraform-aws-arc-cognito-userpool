# ==============================================================================
# BASIC CONFIGURATION
# ==============================================================================

aws_region   = "us-east-1"
project_name = "my-app"
environment  = "dev"

# ==============================================================================
# HOSTED UI CONFIGURATION
# ==============================================================================

create_hosted_ui_domain = true
hosted_ui_domain_prefix = null  # Will use "my-app-dev-auth"

# Update these URLs to match your application
callback_urls        = ["http://localhost:3000/callback", "https://myapp.example.com/callback"]
logout_urls          = ["http://localhost:3000/logout", "https://myapp.example.com/logout"]
default_redirect_uri = "http://localhost:3000/callback"

# ==============================================================================
# OAUTH CONFIGURATION
# ==============================================================================

allowed_oauth_flows  = ["code", "implicit"]
allowed_oauth_scopes = ["email", "openid", "profile", "aws.cognito.signin.user.admin"]

# Identity providers (add more as needed)
supported_identity_providers = ["COGNITO"]

# ==============================================================================
# CLIENT CONFIGURATION
# ==============================================================================

generate_client_secret = false  # Set to true for server-side applications

explicit_auth_flows = [
  "ALLOW_USER_SRP_AUTH",
  "ALLOW_REFRESH_TOKEN_AUTH",
  "ALLOW_USER_PASSWORD_AUTH"
]

# Attributes the client can read/write
read_attributes = [
  "email",
  "email_verified",
  "name",
  "family_name",
  "given_name",
  "preferred_username"
]

write_attributes = [
  "email",
  "name",
  "family_name",
  "given_name",
  "preferred_username"
]

# ==============================================================================
# TOKEN CONFIGURATION
# ==============================================================================

access_token_validity  = 60   # 1 hour
id_token_validity      = 60   # 1 hour
refresh_token_validity = 30   # 30 days

# ==============================================================================
# EMAIL CONFIGURATION
# ==============================================================================

email_verification_method = "CONFIRM_WITH_LINK"  # or "CONFIRM_WITH_CODE"

# ==============================================================================
# PASSWORD POLICY CONFIGURATION
# ==============================================================================

password_minimum_length         = 8
password_require_lowercase      = true
password_require_numbers        = true
password_require_symbols        = true
password_require_uppercase      = true
temporary_password_validity_days = 7

# ==============================================================================
# SECURITY CONFIGURATION
# ==============================================================================

advanced_security_mode = "AUDIT"     # or "ENFORCED" or "OFF"
mfa_configuration     = "OPTIONAL"   # or "ON" or "OFF"
